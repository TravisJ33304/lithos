# Lithos Client Environment Configuration
# Copy this file to .env and fill in the values

# =============================================================================
# GAME SERVER
# =============================================================================

# WebSocket URL to connect to the game server
# In development: ws://localhost:9001
# In production: ws://your-server-host.com:9001
VITE_WS_URL=ws://localhost:9001

# =============================================================================
# CENTRAL API (Optional - for server browser, leaderboards)
# =============================================================================

# Base URL for the Central API
# In development: http://localhost:3000
# In production: https://your-api-domain.com
VITE_API_URL=http://localhost:3000

# =============================================================================
# SUPABASE (Optional - for authentication)
# =============================================================================

# Supabase URL for authentication flows
VITE_SUPABASE_URL=https://your-project.supabase.co

# Supabase anonymous key (public, found in Settings > API)
VITE_SUPABASE_ANON_KEY=your-anon-key-here