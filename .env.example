# Lithos Environment Configuration
# Copy this file to .env and fill in the values

# =============================================================================
# DATABASE
# =============================================================================

# PostgreSQL connection string for player/faction data persistence
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lithos

# =============================================================================
# CENTRAL API (Optional - for server browser / heartbeat reporting)
# =============================================================================

# Base URL for the Central API (lithos-api)
# If running locally with docker-compose, this would be http://api:3000
CENTRAL_API_URL=http://localhost:3000

# Shared secret for server heartbeat authentication
# The game server sends heartbeats to the Central API using this key
CENTRAL_API_KEY=your-secure-random-key-here

# =============================================================================
# SUPABASE AUTHENTICATION
# =============================================================================

# Supabase JWKS URL for JWT validation
# Found in your Supabase dashboard: Settings > API > JWT Settings > JWKS URL
SUPABASE_JWKS_URL=https://your-project.supabase.co/auth/v1/.well-known/jwks

# Expected JWT issuer (optional)
# Typically: https://your-project.supabase.co/auth/v1
SUPABASE_JWT_ISSUER=https://your-project.supabase.co/auth/v1

# Expected JWT audience (optional)
# Typically: your Supabase project URL
SUPABASE_JWT_AUDIENCE=https://your-project.supabase.co

# =============================================================================
# GAME SERVER CONFIGURATION
# =============================================================================

# WebSocket listen address
SERVER_LISTEN_ADDR=0.0.0.0:9001

# Game tick rate (ticks per second) - recommended: 20
SERVER_TICK_RATE=20

# Maximum concurrent players per shard
SERVER_MAX_PLAYERS=100

# World generation seed (deterministic world gen)
# Changing this creates a new world
SERVER_WORLD_SEED=12345

# Public WebSocket URL advertised to clients/server browser
# This is what clients connect to
WS_PUBLIC_URL=ws://localhost:9001

# Unique server identifier for the server browser
SERVER_ID=srv-local-dev

# Display name in server browser
SERVER_NAME=Lithos Dev Server

# Region code for server sorting (e.g., us-east, eu-west, ap-south)
SERVER_REGION=local

# =============================================================================
# RUST LOGGING
# =============================================================================

# Log level: error, warn, info, debug, trace
RUST_LOG=lithos=info