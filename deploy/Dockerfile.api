# Multi-stage build for lithos-api
FROM rust:1.86-slim AS builder

WORKDIR /build
COPY Cargo.toml Cargo.lock ./
COPY crates/ crates/

RUN cargo build --release --bin lithos-api

# Runtime
FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

COPY --from=builder /build/target/release/lithos-api /usr/local/bin/lithos-api

EXPOSE 3000
ENV RUST_LOG=lithos=info

CMD ["lithos-api"]
